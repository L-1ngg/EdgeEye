# EdgeEye backend environment variables.
# Copy this file to `.env` and adjust values for your environment.
# All variables use the EDGEEYE_ prefix and are read by app/core/config.py.

# --- Storage ---
# SQLite database file path.
EDGEEYE_DATABASE_PATH=data/edgeeye.db
# Local static root served at /uploads (raw and annotated images).
EDGEEYE_UPLOADS_DIR=uploads
# Local static root served at /reports (exported report files).
EDGEEYE_REPORTS_DIR=reports

# --- Built-in camera bridge ---
# Starts a no-model USB camera bridge inside the backend process when the
# camera source is available. Set false on machines without a camera.
EDGEEYE_CAMERA_BRIDGE_ENABLED=true
EDGEEYE_CAMERA_SOURCE=/dev/video0
EDGEEYE_CAMERA_CAPTURE_BACKEND=ffmpeg
EDGEEYE_CAMERA_FFMPEG_PATH=ffmpeg
EDGEEYE_CAMERA_V4L2_CTL_PATH=v4l2-ctl
EDGEEYE_CAMERA_WIDTH=640
EDGEEYE_CAMERA_HEIGHT=480
# Realtime display uses MJPEG streaming; this interval only controls how often
# the backend saves a sample frame into latest-result/evidence storage.
EDGEEYE_CAMERA_INTERVAL_SECONDS=5.0
EDGEEYE_CAMERA_STREAM_FPS=30
EDGEEYE_CAMERA_TIMEOUT_SECONDS=5.0
EDGEEYE_CAMERA_MAX_RAW_FRAMES_PER_INSPECTION=120
EDGEEYE_CAMERA_DEVICE_ID=device-001
EDGEEYE_CAMERA_OPERATOR=backend-camera
EDGEEYE_CAMERA_OUTBOX_DIR=data/camera-outbox

# --- LLM repair-advice provider ---
# Provider selector. Use "rule-template" to force local fallback advice,
# or "openai-compatible" to call an OpenAI-style chat-completions endpoint.
EDGEEYE_LLM_PROVIDER=rule-template
# OpenAI-compatible chat-completions URL. Leave empty to use rule-template fallback.
EDGEEYE_LLM_API_URL=
# Backend-only API key. Never returned to the frontend. Leave empty for fallback.
EDGEEYE_LLM_API_KEY=
# Model name sent to the provider and recorded on generated advice.
EDGEEYE_LLM_MODEL_NAME=rule-template
# Provider call timeout in seconds.
EDGEEYE_LLM_TIMEOUT_SECONDS=10
# Retry attempts before falling back to the rule template.
EDGEEYE_LLM_MAX_RETRIES=2

# --- Alarm deduplication ---
# Time window (seconds) within which a duplicate alarm key is suppressed
# instead of reopened. Matches docs/engineering-standards.md default of 300.
EDGEEYE_ALARM_DEDUP_WINDOW_SECONDS=300

# --- CORS ---
# Comma-separated list of allowed frontend origins.
EDGEEYE_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
